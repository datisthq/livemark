{
  "name": "livemark",
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-04-01",
  "preview_urls": true,
  "workers_dev": true,
  "assets": {
    "directory": "./livemark/build",
  },
  "routes": [
    {
      "pattern": "livemark.dev",
      "custom_domain": true,
    },
  ],
}
