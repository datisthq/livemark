{
  "name": "livemark",
  "version": "0.0.0-dev",
  "description": "Livemark description",
  "license": "MIT",
  "author": "Evgeny Karev",
  "repository": "https://github.com/datisthq/livemark",
  "files": [
    "build"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": "./build/index.js",
  "scripts": {
    "build": "tsgo",
    "bump": "ncu -ws -u",
    "clean": "rm -rf pnpm-local.yaml node_modules **/node_modules **/build",
    "format": "vp fmt",
    "lint": "vp fmt --check && vp lint",
    "prepare": "is-ci || lefthook install",
    "release": "pnpm -r publish --access public --ignore-scripts --no-git-checks",
    "setversion": "pnpm -r exec pnpm version --no-git-tag-version",
    "unit": "vp test",
    "start": "pnpm -F website start",
    "test": "pnpm lint && pnpm type && pnpm unit",
    "type": "tsgo --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@cloudflare/vite-plugin": "^1.25.5",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-query": "5.91.3",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "1.168.1",
    "@tanstack/react-router-devtools": "1.166.10",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "es-toolkit": "1.44.0",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "3.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "vite": "8.0.1",
    "vite-plugin-svgr": "4.5.0",
    "wrangler": "4.68.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@semantic-release/exec": "7.1.0",
    "@types/node": "24.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "4.0.16",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "lefthook": "2.1.1",
    "npm-check-updates": "18.0.1",
    "semantic-release": "24.2.9",
    "tempy": "3.2.0",
    "vite-plus": "0.1.12",
    "vitest-polly": "1.4.0"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
