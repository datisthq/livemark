{
  "name": "livemark",
  "version": "0.0.0-dev",
  "description": "Livemark description",
  "license": "MIT",
  "author": "Evgeny Karev",
  "repository": "https://github.com/datisthq/livemark",
  "bin": {
    "livemark": "./build/entrypoints/main.js"
  },
  "files": [
    "build",
    "source",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./build/index.js",
    "./components/*": "./source/components/*.tsx",
    "./elements/*": "./source/elements/*.tsx",
    "./hooks/*": "./source/hooks/*.ts",
    "./styles/*": "./source/styles/*.css",
    "./utils/*": "./source/utils/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.build.json",
    "bump": "ncu -u",
    "docs:build": "node source/entrypoints/main.ts build",
    "docs:start": "node source/entrypoints/main.ts start",
    "format": "vp fmt",
    "lint": "vp fmt --check && vp lint",
    "prepare": "lefthook install",
    "release": "pnpm publish --access public --ignore-scripts --no-git-checks",
    "start": "node source/entrypoints/main.ts",
    "unit": "vp test",
    "test": "pnpm lint && pnpm type && pnpm unit",
    "type": "tsgo --noEmit",
    "leaks": "gitleaks git --config=.gitleaks.toml --verbose --redact",
    "vulns": "semgrep --config=p/typescript --config=p/nodejs --config=p/owasp-top-ten --config=p/secrets --exclude=\"**/fixtures/**\" --metrics=off",
    "scan": "pnpm leaks && pnpm vulns",
    "vers": "pnpm version --no-git-tag-version"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@content-collections/core": "0.14.3",
    "@content-collections/mdx": "0.2.2",
    "@content-collections/vite": "0.3.0",
    "@orama/orama": "^3.1.18",
    "@shikijs/rehype": "4.0.2",
    "@shikijs/twoslash": "^4.0.2",
    "@sindresorhus/slugify": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-query": "5.91.3",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "1.168.1",
    "@tanstack/react-router-devtools": "1.166.10",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.2",
    "@tanstack/virtual-file-routes": "^1.161.7",
    "@types/mdast": "^4.0.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "commander": "14.0.3",
